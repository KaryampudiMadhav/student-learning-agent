{
  "info": {
    "name": "Agent Learning Backend",
    "_postman_id": "b4b304fe-c31e-4a48-afeb-6954be6fcf68",
    "description": "Complete route coverage for backend API with basic happy-path and resilience tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "authToken", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "userName", "value": "Postman User" },
    { "key": "userEmail", "value": "postman_user@example.com" },
    { "key": "userPassword", "value": "Password@123" },
    { "key": "resetToken", "value": "paste-token-from-email" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{userName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register returns 200 or 400', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "",
              "const body = pm.response.json();",
              "if (pm.response.code === 200) {",
              "  pm.test('Register success payload has token', function () {",
              "    pm.expect(body).to.have.property('token');",
              "  });",
              "  pm.collectionVariables.set('authToken', body.token);",
              "}",
              "if (pm.response.code === 400) {",
              "  pm.test('Register duplicate user message exists', function () {",
              "    pm.expect(body).to.have.property('message');",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Login response has token', function () {",
              "  pm.expect(body).to.have.property('token');",
              "});",
              "pm.collectionVariables.set('authToken', body.token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/forgot",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "forgot"]
