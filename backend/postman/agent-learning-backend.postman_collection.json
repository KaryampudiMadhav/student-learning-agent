        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"NewPassword@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/reset/{{resetToken}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "reset", "{{resetToken}}"]
        }
      },
