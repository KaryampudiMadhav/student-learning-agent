              "});",
              "const body = pm.response.json();",
              "pm.test('Forgot response has message or error', function () {",
              "  pm.expect(body.message || body.error).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
