            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Workflow - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/workflow/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "workflow", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Health payload is ok', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Workflow - Run",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('sessionId')) {",
              "  pm.collectionVariables.set('sessionId', pm.variables.replaceIn('{{$guid}}'));",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Workflow run is authenticated', function () {",
              "  pm.expect([200, 401, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('Workflow payload has success and sessionId', function () {",
              "    pm.expect(body.success).to.eql(true);",
              "    pm.expect(body).to.have.property('sessionId');",
              "  });",
              "}",
              "if (pm.response.code === 500) {",
              "  const body = pm.response.json();",
              "  pm.test('Workflow error payload present', function () {",
              "    pm.expect(body).to.have.property('error');",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "x-session-id", "value": "{{sessionId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"goal\": \"Learn Node.js from scratch\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/workflow/run",
          "host": ["{{baseUrl}}"],
          "path": ["api", "workflow", "run"]
        }
      }
    },
